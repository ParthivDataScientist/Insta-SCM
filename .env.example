# ──────────────────────────────────────────────
# Insta-Track — Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Security
# Generate a strong random string for your API key, e.g.: openssl rand -hex 32
# Leave blank to run in open/dev mode (no auth required).
API_KEY=

# CORS — set to your production frontend URL in production
ALLOWED_ORIGIN=http://localhost:5173

# FedEx API (Production) — https://developer.fedex.com
FEDEX_CLIENT_ID=your_fedex_client_id_here
FEDEX_CLIENT_SECRET=your_fedex_client_secret_here
FEDEX_URL=https://apis.fedex.com

# DHL API — https://developer.dhl.com
DHL_API_KEY=your_dhl_api_key_here
DHL_API_SECRET=your_dhl_api_secret_here
