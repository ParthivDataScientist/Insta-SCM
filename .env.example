# Copy to ``.env`` and fill in values. Never commit real secrets.

ENVIRONMENT=development

# Database (SQLite default; use postgresql:// for production)
DATABASE_URL=sqlite:///./sql_app.db

# JWT signing (required unique value when ENVIRONMENT=production)
JWT_SECRET_KEY=replace_with_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Optional: protect mutating routes when enforced in code
API_KEY=

# Web client URL (password reset links, CORS primary origin)
FRONTEND_BASE_URL=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
# Comma-separated extra CORS origins (e.g. preview deployments)
CORS_EXTRA_ORIGINS=

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
SQLALCHEMY_ECHO=false

# Logistics API credentials (leave empty for mock/dev behavior where supported)
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_URL=https://apis.fedex.com
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
DHL_API_KEY=
DHL_API_SECRET=
